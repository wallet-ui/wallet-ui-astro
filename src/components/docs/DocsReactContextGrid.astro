---
import { CardGrid, LinkCard } from '@astrojs/starlight/components';

const items = [
	{
		href: './wallet-ui-account-context',
		title: 'WalletUiAccountContext',
		description: 'The context for the currently selected wallet account.',
	},
	{
		href: './wallet-ui-account-context-provider',
		title: 'WalletUiAccountContextProvider',
		description: 'The provider for the WalletUiAccountContext.',
	},
	{
		href: './wallet-ui-cluster-context',
		title: 'WalletUiClusterContext',
		description: 'The context for the currently selected Solana cluster.',
	},
	{
		href: './wallet-ui-cluster-context-provider',
		title: 'WalletUiClusterContextProvider',
		description: 'The provider for the WalletUiClusterContext.',
	},
	{
		href: './wallet-ui-context',
		title: 'WalletUiContext',
		description: 'The main context for Wallet UI.',
	},
	{
		href: './wallet-ui-context-provider',
		title: 'WalletUiContextProvider',
		description: 'The provider for the WalletUiContext.',
	},
];
---

<CardGrid stagger>
	{items.map((item) => <LinkCard {...item} />)}
</CardGrid>
