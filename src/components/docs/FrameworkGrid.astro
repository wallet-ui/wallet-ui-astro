---
import { CardGrid, LinkCard } from '@astrojs/starlight/components';

const items = [
	{ href: './guides/next', title: 'Next.js', description: 'Set up Wallet UI with Next.js' },
	{ href: './guides/vite', title: 'Vite', description: 'Set up Wallet UI with Vite' },
	{ href: './guides/react-router', title: 'React Router', description: 'Set up Wallet UI with React Router' },
];
---

<CardGrid stagger>
	{items.map((item) => <LinkCard {...item} />)}
</CardGrid>
